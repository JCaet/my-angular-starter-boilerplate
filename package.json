{
  "name": "my-angular-starter-boilerplate",
  "version": "1.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:coverage": "ng test --watch=false --coverage",
    "audit": "yarn npm audit --all",
    "audit:ci": "yarn npm audit --all --recursive",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "lint": "eslint \"src/**/*.{js,ts,html}\"",
    "lint:fix": "eslint \"src/**/*.{js,ts,html}\" --fix",
    "stylelint": "stylelint \"src/**/*.css\"",
    "stylelint:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\"",
    "docs": "compodoc -p tsconfig.app.json -s",
    "analyze": "ng build --source-map && source-map-explorer \"dist/my-angular-app/browser/**/*.js\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/service-worker": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@compodoc/compodoc": "^1.1.23",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.0",
    "@types/node": "^24.0.0",
    "angular-eslint": "^21.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^15.2.0",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.7.0",
    "source-map-explorer": "^2.5.3",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "lint-staged": {
    "*.{ts,html}": "eslint --fix",
    "*.css": "stylelint --fix",
    "*.{ts,html,css,json,md}": "prettier --write"
  }
}
